    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.0.0",
    "nodemon": "^3.1.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0"
  }
}
